# Copy is optional: bin/compose regenerates .env on each run from the host.
# This file documents knobs you may set in the environment before invoking compose.
#
#   export PROJECT=/path/to/app
#   export IMAGE=arch-mise:dev
#   export CACHE_VOLUME=arch-mise-cache
#   ./bin/compose run --rm dev bash -l

IMAGE=arch-mise:dev
IMAGE_USER=dev
# Overridden by bin/compose from id -u / id -g unless you set them first:
# DEV_UID=1000
# DEV_GID=1000
CACHE_VOLUME=arch-mise-cache
CACHE_ROOT=/cache
# Absolute project path to mount at /work (bin/compose resolves PROJECT or $PWD):
# PROJECT_MOUNT=/home/you/src/my-app
COMPOSE_PROJECT_NAME=arch-mise
